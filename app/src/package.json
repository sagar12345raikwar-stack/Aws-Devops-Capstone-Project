{
  "name": "enterprise-devops-app",
  "version": "2.0.0",
  "description": "Enterprise DevOps Capstone Project Application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --testPathPattern=tests/",
    "test:watch": "jest --watch",
    "test:integration": "jest tests/integration/",
    "test:e2e": "jest tests/e2e/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security-check": "npm audit --audit-level=critical",
    "dependency-check": "npx audit-ci --critical",
    "docker:build": "docker build -t enterprise-devops-app .",
    "docker:run": "docker run -p 3000:3000 --env-file .env enterprise-devops-app",
    "docker:test": "docker build -t enterprise-devops-app-test --target test .",
    "coverage": "jest --coverage && open coverage/lcov-report/index.html"
  },
  "keywords": ["devops", "kubernetes", "aws", "ci-cd", "production", "enterprise"],
  "author": "DevOps Engineer",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "redis": "^4.6.7",
    "dotenv": "^16.0.3",
    "winston": "^3.9.0",
    "express-rate-limit": "^6.10.0",
    "opossum": "^8.0.0",
    "uuid": "^9.0.0",
    "axios": "^1.4.0",
    "prom-client": "^14.2.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.45.0",
    "nodemon": "^2.0.22",
    "@types/jest": "^29.5.3",
    "jest-junit": "^16.0.0",
    "@types/node": "^20.4.5",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "@types/express": "^4.17.17",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "reporters": [
      "default",
      "jest-junit"
    ],
    "setupFilesAfterEnv": ["./tests/setup.js"]
  }
}
